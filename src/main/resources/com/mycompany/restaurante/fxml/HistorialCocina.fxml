<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="560.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.mycompany.restaurante.Controlador.HistorialCocinaController">

    <!-- ══ HEADER ══════════════════════════════════════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="70.0"
              style="-fx-background-color: #2c3b62;">
            <children>
                <ImageView fitHeight="50.0" fitWidth="150.0"
                           pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../../../../img/tipoAzul.png" />
                    </image>
                    <HBox.margin><Insets left="35.0" right="20.0" /></HBox.margin>
                </ImageView>
                <Region HBox.hgrow="ALWAYS" />
                <Label alignment="CENTER" text="Cocina" textFill="#f5efe6">
                    <font><Font name="Franklin Gothic Heavy" size="30.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>
    </top>

    <!-- ══ SIDEBAR ══════════════════════════════════════════════════════ -->
    <left>
        <VBox prefWidth="220.0" style="-fx-background-color: #1a1e2e;"
              BorderPane.alignment="TOP_CENTER">
            <children>
                <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                    <VBox.margin>
                        <Insets left="20.0" right="20.0" top="25.0" />
                    </VBox.margin>
                    <children>
                        <Button fx:id="btnPedidosActuales"
                                mnemonicParsing="false"
                                onAction="#handlePedidosActuales"
                                prefHeight="42.0" prefWidth="180.0"
                                style="-fx-background-color: #8b1a1a; -fx-background-radius: 10 10 10 10;"
                                text="Pedidos Actuales" textFill="#d4c5b0">
                            <font><Font name="Candara Bold" size="19.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                        <Button fx:id="btnHistorial"
                                mnemonicParsing="false"
                                onAction="#handleHistorial"
                                prefHeight="42.0" prefWidth="180.0"
                                style="-fx-background-color: #2c3b62; -fx-background-radius: 10 10 10 10;"
                                text="Historial" textFill="#d4c5b0">
                            <font><Font name="Candara Bold" size="19.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                    </children>
                </VBox>
                <VBox>
                    <VBox.margin>
                        <Insets bottom="25.0" left="20.0" right="20.0" top="15.0" />
                    </VBox.margin>
                    <children>
                        <Button fx:id="btnCerrarSesion"
                                cancelButton="true"
                                mnemonicParsing="false"
                                onAction="#handleCerrarSesion"
                                prefHeight="42.0" prefWidth="180.0"
                                style="-fx-background-color: #8b1a1a; -fx-background-radius: 10 10 10 10;"
                                text="Cerrar sesión" textFill="#d4c5b0">
                            <font><Font name="Candara Bold" size="19.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                    </children>
                </VBox>
            </children>
        </VBox>
    </left>

    <!-- ══ CONTENIDO CENTRAL ════════════════════════════════════════════ -->
    <center>
        <VBox style="-fx-background-color: #f5efe6;"
              BorderPane.alignment="CENTER">
            <children>

                <!-- Título -->
                <HBox alignment="CENTER_LEFT" prefHeight="60.0"
                      style="-fx-background-color: #f5efe6;">
                    <children>
                        <Label text="Historial de Cocina" textFill="#1a1e2e">
                            <font><Font name="Candara Bold" size="25.0" /></font>
                            <HBox.margin><Insets left="20.0" /></HBox.margin>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>

                <Separator style="-fx-background-color: #c9a84c;" />

                <!-- ── FILTROS ── -->
                <HBox alignment="CENTER_LEFT" prefHeight="55.0" spacing="20.0"
                      style="-fx-background-color: #f5efe6;">
                    <HBox.margin><Insets left="20.0" right="20.0" top="10.0" /></HBox.margin>
                    <children>
                        <Label text="Fecha:" textFill="#1a1e2e">
                            <font><Font name="Candara Bold" size="14.0" /></font>
                        </Label>
                        <DatePicker fx:id="dpFecha" prefHeight="30.0" prefWidth="150.0"
                                    style="-fx-background-color: #F7F4ED; -fx-border-color: #1A1E2E; -fx-border-radius: 5;" />

                        <Label text="Turno:" textFill="#1a1e2e">
                            <font><Font name="Candara Bold" size="14.0" /></font>
                        </Label>

                        <!-- RadioButtons comparten el mismo ToggleGroup -->
                        <RadioButton fx:id="rbMatutino" text="Matutino (06–14 hrs)"
                                     textFill="#1a1e2e">
                            <toggleGroup>
                                <ToggleGroup fx:id="tgTurno" />
                            </toggleGroup>
                            <font><Font name="Candara" size="13.0" /></font>
                        </RadioButton>
                        <RadioButton fx:id="rbVespertino" text="Vespertino (15–22 hrs)"
                                     textFill="#1a1e2e"
                                     toggleGroup="$tgTurno">
                            <font><Font name="Candara" size="13.0" /></font>
                        </RadioButton>

                        <Region HBox.hgrow="ALWAYS" />

                        <Button fx:id="btnBuscar"
                                mnemonicParsing="false"
                                onAction="#handleBuscar"
                                prefHeight="30.0" prefWidth="90.0"
                                style="-fx-background-color: #8b1a1a; -fx-background-radius: 10 10 10 10;"
                                text="Buscar" textFill="#d4c5b0">
                            <font><Font name="Candara Bold" size="14.0" /></font>
                            <cursor><Cursor fx:constant="HAND" /></cursor>
                        </Button>
                    </children>
                </HBox>

                <Separator style="-fx-background-color: #d4c5b0;" />

                <!-- ── RESUMEN DEL TURNO ── -->
                <GridPane prefHeight="55.0" prefWidth="680.0"
                          style="-fx-background-color: #2c3b62;">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" prefWidth="170.0" />
                        <ColumnConstraints hgrow="SOMETIMES" prefWidth="170.0" />
                        <ColumnConstraints hgrow="SOMETIMES" prefWidth="170.0" />
                        <ColumnConstraints hgrow="SOMETIMES" prefWidth="170.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints prefHeight="55.0" />
                    </rowConstraints>
                    <children>
                        <!-- Fecha -->
                        <VBox alignment="CENTER" GridPane.columnIndex="0">
                            <children>
                                <Label text="FECHA" textFill="#c9a84c">
                                    <font><Font name="Candara Bold" size="10.0" /></font>
                                </Label>
                                <Label fx:id="lblFechaResumen" text="—" textFill="#f5efe6">
                                    <font><Font name="Candara Bold" size="15.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                        <!-- Turno -->
                        <VBox alignment="CENTER" GridPane.columnIndex="1">
                            <children>
                                <Label text="TURNO" textFill="#c9a84c">
                                    <font><Font name="Candara Bold" size="10.0" /></font>
                                </Label>
                                <Label fx:id="lblTurnoResumen" text="—" textFill="#f5efe6">
                                    <font><Font name="Candara Bold" size="15.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                        <!-- Total órdenes -->
                        <VBox alignment="CENTER" GridPane.columnIndex="2">
                            <children>
                                <Label text="ÓRDENES COMPLETADAS" textFill="#c9a84c">
                                    <font><Font name="Candara Bold" size="10.0" /></font>
                                </Label>
                                <Label fx:id="lblTotalOrdenes" text="0" textFill="#f5efe6">
                                    <font><Font name="Candara Bold" size="22.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                        <!-- Monto total -->
                        <VBox alignment="CENTER" GridPane.columnIndex="3">
                            <children>
                                <Label text="MONTO DEL TURNO" textFill="#c9a84c">
                                    <font><Font name="Candara Bold" size="10.0" /></font>
                                </Label>
                                <Label fx:id="lblMontoTotal" text="$0.00" textFill="#f5efe6">
                                    <font><Font name="Candara Bold" size="18.0" /></font>
                                </Label>
                            </children>
                        </VBox>
                    </children>
                </GridPane>

                <!-- ── TABLAS ── -->
                <HBox prefHeight="310.0" spacing="10.0" VBox.vgrow="ALWAYS">
                    <HBox.margin>
                        <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
                    </HBox.margin>
                    <children>

                        <!-- Tabla maestra: órdenes -->
                        <VBox prefWidth="340.0" spacing="6.0">
                            <children>
                                <Label text="Órdenes del turno" textFill="#1a1e2e">
                                    <font><Font name="Candara Bold" size="13.0" /></font>
                                </Label>
                                <TableView fx:id="tablaOrdenes"
                                           prefHeight="270.0" prefWidth="330.0"
                                           style="-fx-background-radius: 10; -fx-border-radius: 10;"
                                           stylesheets="@../../../../css/stylesTabla.css"
                                           VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colIdOrden"  prefWidth="75.0"  text="Orden"  />
                                        <TableColumn fx:id="colMesa"     prefWidth="75.0"  text="Mesa"   />
                                        <TableColumn fx:id="colEstado"   prefWidth="90.0"  text="Estado" />
                                        <TableColumn fx:id="colItems"    prefWidth="80.0"  text="Unids." />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>

                        <!-- Tabla detalle: ítems de la orden seleccionada -->
                        <VBox prefWidth="290.0" spacing="6.0" HBox.hgrow="ALWAYS">
                            <children>
                                <Label text="Detalle de la orden seleccionada" textFill="#1a1e2e">
                                    <font><Font name="Candara Bold" size="13.0" /></font>
                                </Label>
                                <TableView fx:id="tablaDetalle"
                                           prefHeight="200.0" prefWidth="280.0"
                                           style="-fx-background-radius: 10; -fx-border-radius: 10;"
                                           stylesheets="@../../../../css/stylesTabla.css"
                                           VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colCantidad"  prefWidth="45.0"  text="Cant." />
                                        <TableColumn fx:id="colProducto"  prefWidth="120.0" text="Platillo" />
                                        <TableColumn fx:id="colPrecioUnit" prefWidth="70.0" text="P. Unit." />
                                        <TableColumn fx:id="colSubtotal"  prefWidth="70.0"  text="Subtotal" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>

                                <!-- Notas del mesero -->
                                <VBox spacing="3.0">
                                    <children>
                                        <Label text="Notas del mesero:" textFill="#8b6914">
                                            <font><Font name="Candara Bold" size="12.0" /></font>
                                        </Label>
                                        <Label fx:id="lblNotasOrden"
                                               text="—"
                                               textFill="#1a1e2e"
                                               wrapText="true"
                                               prefWidth="280.0">
                                            <font><Font name="Candara" size="12.0" /></font>
                                        </Label>
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </HBox>

            </children>
        </VBox>
    </center>

</BorderPane>
